{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/app.js", "dest": "/public/app.js" }
  ]
}
